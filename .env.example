# ── 敏感配置 ──
BOT_TOKEN=1234567890:replace_with_your_telegram_bot_token
DEEPSEEK_KEY=sk-replace_with_your_deepseek_api_key
ALLOWED_ID=123456789

# ── 世界与模型 ──
ACTIVE_WORLD=one
MODEL_NAME=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ── 上下文与短期记忆 ──
CONTEXT_LENGTH=60
MEMORY_MAX_LENGTH=200

# ── 回复长度 ──
MIN_REPLY_TOKENS=700
MID_REPLY_TOKENS=2400
MAX_REPLY_TOKENS=3400

# ── Telegram 消息分段 ──
SPLIT_THRESHOLD=3000
CONTINUE_LIMIT=7

# ── 长期记忆 ──
MEMO_SIZE_LIMIT=500
LONG_MEMORY_CONTEXT_LIMIT=12
LONG_MEMORY_MAX_ITEMS=12
AUTO_MEMORY_INTERVAL=26
AUTO_MEMORY_LOOKBACK=32
LONG_MEMORY_REFINE_BUFFER=4
MEMO_REMINDER_INTERVAL=40
RESET_CONFIRM_SECONDS=30

# ── NPC主动行为系统 ──
NPC_BASE_ACTIVATION=0.5
NPC_MAX_ACTIONS_PER_CHECK=1
NPC_TIMER_INTERVAL=300
NPC_ACTION_MAX_TOKENS=200
NPC_TIMER_ACTIVATION_MULTIPLIER=0.6
NPC_CONTEXT_BOOST_MULTIPLIER=2.0

# ── Web 管理面板 ──
WEB_PORT=8080
WEB_HOST=0.0.0.0
WEB_PASSWORD=change_me
